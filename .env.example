# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Meta WhatsApp Cloud API ────────────────────────────────────────────────────
# Get from: https://developers.facebook.com/ → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAxxxxx...
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=carbolo_verify_token
WHATSAPP_APP_SECRET=                        # optional, for signature verification

# ── Google Calendar ────────────────────────────────────────────────────────────
# Calendar ID from: Google Calendar → Settings → your calendar → Calendar ID
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
# Path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ── App ────────────────────────────────────────────────────────────────────────
PORT=8000
ENV=production
# Set to "true" to fire reminders in 2min/5min for demo purposes
DEMO_MODE=false
