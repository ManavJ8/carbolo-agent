# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio WhatsApp ────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com (Account Info on dashboard)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Google Calendar ────────────────────────────────────────────────────────────
# Calendar ID from: Google Calendar → Settings → your calendar → Calendar ID
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
# Path to service account JSON key file (local dev only)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# For production (Render): paste entire service_account.json contents here
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── App ────────────────────────────────────────────────────────────────────────
PORT=8000
ENV=production
# Set to "true" to fire reminders in 2min/5min for demo purposes
DEMO_MODE=false